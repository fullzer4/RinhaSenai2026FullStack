generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Tabela principal de transacoes.
// Indices pensados para os dois hot-paths criticos sob concorrencia:
//  1) lookup por idempotencyKey (unique) -> usado para deduplicar requests identicos
//  2) soma do limite diario por cartao   -> (cardLast4, status, createdAt)
model Transaction {
  id                String   @id @default(uuid())
  status            String   // approved | declined | refunded
  cardLast4         String   @map("card_last4")
  cardBrand         String   @map("card_brand")
  holderName        String   @map("holder_name")
  amountCents       Int      @map("amount_cents")
  installments      Int      @default(1)
  installmentAmount Int      @map("installment_amount")
  totalWithInterest Int      @map("total_with_interest")
  feeCents          Int      @map("fee_cents")
  netAmount         Int      @map("net_amount")
  description       String
  idempotencyKey    String?  @unique @map("idempotency_key")
  createdAt         DateTime @default(now()) @map("created_at")

  // Indice composto: soma rapida do limite diario aprovado por cartao.
  @@index([cardLast4, status, createdAt], name: "idx_card_status_created")
  // Indice para paginacao por data (ORDER BY createdAt DESC).
  @@index([createdAt], name: "idx_created_at")
  // Indice para filtros/agregacoes por status (balance endpoint).
  @@index([status], name: "idx_status")
  @@map("transactions")
}
